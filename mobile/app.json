{
  "expo": {
    "name": "Argus",
    "slug": "argus",
    "scheme": "argus",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F2EBDD"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.argus.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.argus.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4A7A67"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supabaseUrl": "https://horovpvgimtbbeuvzgpd.supabase.co",
      "router": {},
      "eas": {
        "projectId": "cc27419a-43f4-41db-a96a-50f5c01c23b7"
      }
    },
    "owner": "treyvititoe"
  }
}
